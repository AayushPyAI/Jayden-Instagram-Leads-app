# Copy to .env and fill in values. Never commit .env.

# Required — Google Gemini API key for screenshot extraction
GEMINI_API_KEY=

# Required for workbook storage (production uses S3)
WORKBOOK_STORAGE=s3
S3_BUCKET=
S3_PREFIX=prod
AWS_DEFAULT_REGION=us-east-1

# AWS credentials (local dev only; ECS uses task role in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Server
PORT=8501
LOG_LEVEL=INFO

# Optional tuning (defaults shown)
# GEMINI_MODEL=models/gemini-2.5-flash
# PROCESS_CHUNK_SIZE=25
# MAX_SCREENSHOTS_PER_REQUEST=50
# GEMINI_CONCURRENCY=8
# GEMINI_MAX_RETRIES=2
# GEMINI_RETRY_BACKOFF_S=1.5
# GEMINI_TIMEOUT_S=25
# GEMINI_FALLBACK_MODEL=
# GEMINI_DISCOVER_MODELS=false
# MAX_IMAGE_SIDE=1600
# EXPORT_FILENAME_STEM=instagram_leads

# ── URL Lead Pipeline (Apify followers → RapidAPI profile → filter → leads) ──
# Required to use the URL Pipeline page. Leave blank to keep that feature disabled.

# Apify (follower scraping)
APIFY_TOKEN=
# Actor that returns followers for given handles (default: the configured Instagram followers actor).
APIFY_FOLLOWERS_ACTOR_ID=lezdhAFfa4H5zAb2A

# RapidAPI (per-profile detail)
RAPIDAPI_KEY=
RAPIDAPI_HOST=instagram120.p.rapidapi.com
# Profile endpoint differs per listing. Copy these from the RapidAPI playground
# "Code Snippets" if a profile lookup returns 404/empty with the defaults below.
# RAPIDAPI_PROFILE_PATH=api/instagram/userInfoByUsername
# RAPIDAPI_PROFILE_METHOD=POST
# RAPIDAPI_USERNAME_PARAM=username

# Pipeline tuning (defaults shown)
# URL_PIPELINE_MAX_SEED_URLS=20
# APIFY_MAX_FOLLOWERS_PER_URL=400
# APIFY_DEMO_FALLBACK=true
# URL_PIPELINE_CONCURRENCY=5
# RAPIDAPI_DAILY_CALL_CAP=8000
# RAPIDAPI_TIMEOUT_S=25
# RAPIDAPI_MAX_RETRIES=2
# RAPIDAPI_RETRY_BACKOFF_S=1.5
# APIFY_TIMEOUT_S=120
# SKIP_PRIVATE_ACCOUNTS=true

# Profile cache (skip RapidAPI when username was checked recently)
# PROFILE_CACHE_ENABLED=true
# PROFILE_CACHE_DAYS=30
# PROFILE_CACHE_PATH=data/profile_cache.db
