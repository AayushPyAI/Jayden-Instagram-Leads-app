# Copy to .env and fill in values. Never commit .env.

# Required — Google Gemini API key for screenshot extraction
GEMINI_API_KEY=

# Required for workbook storage (production uses S3)
WORKBOOK_STORAGE=s3
S3_BUCKET=
S3_PREFIX=prod
AWS_DEFAULT_REGION=us-east-1

# AWS credentials (local dev only; ECS uses task role in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Server
PORT=8501
LOG_LEVEL=INFO

# Optional tuning (defaults shown)
# GEMINI_MODEL=models/gemini-2.5-flash
# PROCESS_CHUNK_SIZE=25
# MAX_SCREENSHOTS_PER_REQUEST=50
# GEMINI_CONCURRENCY=8
# GEMINI_MAX_RETRIES=2
# GEMINI_RETRY_BACKOFF_S=1.5
# GEMINI_TIMEOUT_S=25
# GEMINI_FALLBACK_MODEL=
# GEMINI_DISCOVER_MODELS=false
# MAX_IMAGE_SIDE=1600
# EXPORT_FILENAME_STEM=instagram_leads
